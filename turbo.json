{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "CI",
    "GITHUB_TOKEN",
    "LEGACY_PLAYWRIGHT_BASE_URL",
    "NODE_AUTH_TOKEN",
    "NODE_ENV",
    "NPM_TOKEN",
    "PLAYWRIGHT_BASE_URL",
    "ROLLUP_PACKAGES",
    "npm_config_user_agent"
  ],
  "tasks": {
    "build": {
      "outputs": ["dist/**", "lib/**"],
      "cache": true
    },
    "clean": {
      "cache": false,
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": true
    },
    "test": {
      "outputs": [],
      "cache": false
    }
  }
}
