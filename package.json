{
  "name": "slate-packages",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm build:packages && pnpm build:next",
    "build:next": "cd ./site && next build",
    "build:packages": "turbo --filter \"./packages/*\" build --concurrency=1",
    "changesetversion": "pnpm changeset version && pnpm install && git add .",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:integration-local",
    "check:ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:integration",
    "clean": "turbo --filter \"./packages/*\" clean && rimraf './site/{.next,out,node_modules}' --glob",
    "dev": "pnpm serve",
    "fix": "pnpm lint:fix",
    "internal:release:next": "pnpm prerelease && pnpm changeset publish --tag next",
    "lint": "biome check .",
    "lint:eslint": "eslint .",
    "lint:fix": "biome check . --fix",
    "lint:release": "pnpm typecheck",
    "lint:typescript": "pnpm typecheck",
    "open": "open http://localhost:3100",
    "playwright": "playwright test",
    "prerelease": "NODE_ENV=production pnpm build:packages && pnpm test && pnpm lint",
    "release": "pnpm build && pnpm changeset publish",
    "release:experimental": "pnpm prerelease && pnpm changeset publish --tag experimental",
    "release:latest": "pnpm prerelease && pnpm changeset publish",
    "release:next": "pnpm prerelease && pnpm changeset publish --tag next",
    "release:publish:experimental": "pnpm changeset publish --tag experimental",
    "release:publish:latest": "pnpm changeset publish",
    "release:publish:next": "pnpm changeset publish --tag next",
    "serve": "cd ./site && next dev -p 3100",
    "serve:playwright": "node ./scripts/serve-playwright.mjs",
    "test": "pnpm run test:bun && pnpm run test:vitest",
    "test:bun": "bun test ./packages/slate-hyperscript/test/index.spec.ts ./packages/slate-react/test/bun ./packages/slate/test/index.spec.ts ./packages/slate/test/utils/string.ts ./packages/slate-history/test/index.spec.ts",
    "test:inspect": "pnpm test --inspect-brk",
    "test:integration": "playwright install --with-deps && playwright test",
    "test:integration-docker": "./playwright/docker/run-tests.sh",
    "test:integration-local": "playwright install && playwright test",
    "test:vitest": "pnpm --dir ./packages/slate-react exec vitest run --config ./vitest.config.mjs",
    "typecheck": "pnpm typecheck:packages && pnpm typecheck:site && pnpm typecheck:root",
    "typecheck:root": "pnpm exec tsc --project ./tsconfig.json --noEmit",
    "typecheck:packages": "turbo --filter \"./packages/*\" typecheck --concurrency=1",
    "typecheck:site": "cd ./site && tsc --project tsconfig.json"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "bun-types": "1.3.10",
    "@changesets/changelog-github": "^0.4.8",
    "@changesets/cli": "^2.26.2",
    "@emotion/css": "^11.11.2",
    "@faker-js/faker": "^10.0.0",
    "@happy-dom/global-registrator": "^20.9.0",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/is-hotkey": "^0.1.10",
    "@types/is-url": "^1.2.32",
    "@types/lodash": "^4.14.200",
    "@types/node": "^20.8.7",
    "@types/prismjs": "^1.26.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "image-extensions": "^1.1.0",
    "is-hotkey": "^0.2.0",
    "is-url": "^1.2.4",
    "lodash": "^4.17.21",
    "next": "^16.2.4",
    "prismjs": "^1.29.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^4.0.11",
    "rimraf": "^5.0.5",
    "serve-handler": "^6.1.7",
    "slate": "workspace:*",
    "slate-dom": "workspace:*",
    "slate-history": "workspace:*",
    "slate-hyperscript": "workspace:*",
    "slate-react": "workspace:*",
    "tsdown": "^0.16.6",
    "turbo": "2.9.5",
    "typescript": "5.2.2",
    "ultracite": "7.4.4"
  },
  "packageManager": "pnpm@9.15.0"
}
