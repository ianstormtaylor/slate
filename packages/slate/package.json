{
  "name": "slate",
  "description": "A completely customizable framework for building rich text editors.",
  "version": "0.124.1",
  "license": "MIT",
  "repository": "git://github.com/ianstormtaylor/slate.git",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "pnpm exec tsdown --config ../../config/tsdown.config.mts --log-level warn",
    "clean": "rimraf dist lib",
    "typecheck": "pnpm exec tsc --project tsconfig.json --noEmit && pnpm exec tsc --project test/tsconfig.custom-types.json --noEmit"
  },
  "devDependencies": {
    "lodash": "^4.17.21",
    "slate-hyperscript": "^0.115.0"
  },
  "keywords": [
    "canvas",
    "contenteditable",
    "custom",
    "document",
    "edit",
    "editor",
    "html",
    "immutable",
    "markdown",
    "medium",
    "paper",
    "react",
    "rich",
    "richtext",
    "richtext",
    "slate",
    "text",
    "wysiwyg",
    "wysiwym"
  ]
}
