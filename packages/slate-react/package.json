{
  "name": "slate-react",
  "description": "Tools for building completely customizable richtext editors with React.",
  "version": "0.124.0",
  "license": "MIT",
  "repository": "git://github.com/ianstormtaylor/slate.git",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.es.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs"
    }
  },
  "umd": "dist/slate-react.js",
  "umdMin": "dist/slate-react.min.js",
  "sideEffects": false,
  "files": [
    "dist/"
  ],
  "dependencies": {
    "@juggle/resize-observer": "^3.4.0",
    "direction": "^1.0.4",
    "is-hotkey": "^0.2.0",
    "lodash": "^4.17.21",
    "scroll-into-view-if-needed": "^3.1.0",
    "tiny-invariant": "1.3.1"
  },
  "scripts": {
    "build": "ROLLUP_PACKAGES=slate-react pnpm --dir ../.. build:rollup",
    "clean": "rimraf dist lib",
    "test": "node ../../scripts/run-from-root.mjs pnpm exec jest --config jest.config.js",
    "typecheck": "pnpm exec tsc --project tsconfig.build.json --noEmit --pretty false"
  },
  "devDependencies": {
    "@babel/runtime": "^7.23.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.0.0",
    "@types/is-hotkey": "^0.1.8",
    "@types/jest": "29.5.6",
    "@types/jsdom": "^21.1.4",
    "@types/lodash": "^4.14.200",
    "@types/node": "^20.8.7",
    "@types/react": "^18.2.41",
    "@types/react-dom": "^18.2.17",
    "@types/resize-observer-browser": "^0.1.8",
    "direction": "^1.0.4",
    "jsdom": "^26.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "scroll-into-view-if-needed": "^3.1.0",
    "slate": "workspace:*",
    "slate-dom": "workspace:*",
    "slate-history": "workspace:*",
    "slate-hyperscript": "workspace:*",
    "source-map-loader": "^4.0.1",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0",
    "slate": ">=0.121.0",
    "slate-dom": ">=0.119.1"
  },
  "umdGlobals": {
    "react": "React",
    "slate-dom": "SlateDom",
    "slate": "Slate"
  },
  "keywords": [
    "canvas",
    "contenteditable",
    "docs",
    "document",
    "edit",
    "editor",
    "editable",
    "html",
    "immutable",
    "markdown",
    "medium",
    "paper",
    "react",
    "rich",
    "richtext",
    "richtext",
    "slate",
    "text",
    "wysiwyg",
    "wysiwym"
  ]
}
